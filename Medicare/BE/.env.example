# Server
PORT=8000
NODE_ENV=development

# URL frontend — local hoặc production (nhiều URL cách nhau bằng dấu phẩy)
CLIENT_URL=http://localhost:3000
# Thêm origin production nếu cần:
# CORS_ORIGINS=https://your-app.vercel.app,https://www.your-domain.com

# Bật true nếu chưa cấu hình email SMTP (khuyến nghị khi mới deploy)
SKIP_EMAIL_VERIFICATION=true

# MongoDB — local hoặc MongoDB Atlas
MONGODB_URI=mongodb://127.0.0.1:27017/medicare_ai
# Tự dùng in-memory DB nếu MongoDB local chưa cài (dev)
USE_IN_MEMORY_DB=true

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=MediCare AI Clinic <your_gmail@gmail.com>

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Google Gemini AI
GEMINI_API_KEY=${GEMINI_API_KEY}
GEMINI_MODEL=gemini-3.1-flash-lite
